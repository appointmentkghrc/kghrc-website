generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model Blog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  author      String
  category    String
  image       String?
  status      String   @default("draft")
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blogs")
}

model Doctor {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  designation String
  qualification String?
  experience  String?
  bio         String?
  appointmentLink String?
  email       String?
  phone       String?
  facebook    String?
  linkedin    String?
  image       String?
  sortOrder   Int?     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("doctors")
}

model Testimonial {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  designation String
  content     String
  rating      Int      @default(5)
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("testimonials")
}

model Statistic {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  label     String
  value     String
  icon      String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("statistics")
}

model SiteSetting {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  key           String   @unique
  officeAddress String
  primaryPhone  String
  secondaryPhone String
  primaryEmail  String
  secondaryEmail String
  mapEmbedUrl   String
  facebookUrl   String?
  instagramUrl  String?
  twitterUrl    String?
  youtubeUrl    String?
  linkedinUrl   String?
  heroBackgroundImage String?
  heroTitleLine1 String?
  heroTitleLine2 String?
  heroDescription String?
  heroCtaLabel   String?
  heroCtaHref    String?
  doctorsSectionDescription String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("site_settings")
}

model DiagnosticService {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  title       String
  description String
  details     String
  image       String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("diagnostic_services")
}

model GallerySection {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  title       String
  bannerImage String?
  sections    String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("gallery_sections")
}

model GalleryImage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl  String
  category  String   @default("General")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gallery_images")
}

model AboutSection {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  key                   String   @unique
  heroTitle             String   @default("About Us")
  heroBreadcrumb        String   @default("HOME › ABOUT")
  heroBackgroundImage   String
  aboutTagline          String
  profileTitle          String
  profileDescription    String
  profileImagePrimary   String
  profileImageSecondary String
  contactTitle          String
  contactDescription    String
  contactButtonLabel    String
  contactButtonHref     String
  openingHoursTitle     String
  openingHoursRows      String[] @default([])
  cancerTitle           String
  cancerDescription     String
  cancerButtonLabel     String
  cancerButtonHref      String
  missionTitle          String
  missionPoints         String[] @default([])
  visionTitle           String
  visionPoints          String[] @default([])
  diagnosticTitle       String
  diagnosticItems       String[] @default([])
  facilitiesTitle       String
  facilitiesItems       String[] @default([])
  servicesTitle         String
  servicesItems         String[] @default([])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("about_sections")
}

model TpaInsurancePartner {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  logoUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tpa_insurance_partners")
}
